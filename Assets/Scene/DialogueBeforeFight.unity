      propertyPath: m_LocalEulerAnglesHint.z
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: npcName
      value: Master Dojo
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: autoTrigger
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: triggerOnce
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: nextSceneName
      value: Level 3-2
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.size
      value: 11
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: waitBeforeTransition
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sfxPerLine.Array.size
      value: 11
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[0]
      value: 'Yu: It''s over, Sifu. The experiments, the torture... I''m ending your
        twisted legacy right here.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[1]
      value: 'Sifu : Look at yourself, Yu. Drenched in the blood of your brothers.
        There was no girl. There was no tragedy but the one you are causing now.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[2]
      value: 'Yu : Shut up! I heard her screams! I remember her face!'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[3]
      value: 'Sifu: You remember what the parasite WANTS you to remember! It hijacked
        your guilt and fabricated a love story to turn you into its executioner!
        Please, Yu, fight it!'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[4]
      value: 'Shadow: HE LIES! He is trying to steal her from you again! Strike him
        down! NOW!'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[5]
      value: 'Yu: Don''t you dare speak of her! This is for what you did to us!'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[6]
      value: 'Sifu : You... were the executioner, Yu... I only tried... to keep the
        monster... contained...'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[7]
      value: 'Yu : Argh! It''s done... but my chest... why does it feel like...'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[8]
      value: 'The Orb : You have served your purpose beautifully, puppet. Your rage...
        your blind, pathetic love... it was the perfect feast.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[9]
      value: 'Yu : You... you weren''t trapped... You are the monster...'
      objectReference: {fileID: 0}
