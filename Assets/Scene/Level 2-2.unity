    - target: {fileID: 8440353871128596882, guid: 48f01e1c40239744dbb9ce6f4b55e385, type: 3}
      propertyPath: sentences.Array.data[0]
      value: 'Yu : No... NO! She was begging him... Sifu, you monster! You tortured
        her!'
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 48f01e1c40239744dbb9ce6f4b55e385, type: 3}
      propertyPath: sentences.Array.data[1]
      value: 'Shadow: Listen to her agony, Yu. I am an ancient spirit of these ruins.
        Sifu trapped me in his machine, and she was his sacrifice to siphon my power.'
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 48f01e1c40239744dbb9ce6f4b55e385, type: 3}
      propertyPath: sentences.Array.data[2]
      value: 'Shadow: Listen to her agony, Yu. I am an ancient spirit of these ruins.
        Sifu trapped me in his machine, and she was his sacrifice to siphon my power.'
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596882, guid: 48f01e1c40239744dbb9ce6f4b55e385, type: 3}
      propertyPath: sentences.Array.data[3]
      value: 'Shadow: I only escaped by hiding within your soul during the blast.
        We are both his victims.'
      objectReference: {fileID: 0}
    - target: {fileID: 8440353871128596883, guid: 48f01e1c40239744dbb9ce6f4b55e385, type: 3}
