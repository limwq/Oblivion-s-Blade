      propertyPath: sentences.Array.data[0]
      value: 'Yu: The Dojo... I used to call this place home. Now it just smells
        like Sifu''s lies.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[1]
      value: 'Shadow: Home is where the slaughter is, Yu. Paint these paper walls
        red. Spare no one.'
      objectReference: {fileID: 0}
