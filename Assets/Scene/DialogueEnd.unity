      value: 10
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sfxPerLine.Array.size
      value: 10
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[0]
      value: '[Audio Replay]'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[1]
      value: 'Sifu : "Yu, drag that prisoner to the side and start the machine."'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[2]
      value: 'Prisoner : "Leave me... don''t touch me! What do you guys want to do
        to me? ARGH!"'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[3]
      value: 'Yu: Power output at maximum, Sifu. She won''t last long.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[4]
      value: 'Prisoner: "Leave me! ARGH! Don''t... don''t do this to me! ARGH! You
        monster! ARGHHHHHHHH!'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[5]
      value: (Explosion)
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[6]
      value: '[Audio Stop]'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[7]
      value: 'Yu: No... That''s not... That wasn''t me. She was... we were...'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[8]
      value: 'Yu: There was no love. I wasn''t saving anyone... I was just... the
        executioner.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sentences.Array.data[9]
      value: 'Yu: You tried to contain it... to contain me. And I killed you for
        it.'
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: transitionAfterDialogue
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sfxPerLine.Array.data[0]
      value: machine start end
      objectReference: {fileID: 0}
    - target: {fileID: 6207481195272863996, guid: 2c97712523364cb4594f5de93e0700d4, type: 3}
      propertyPath: sfxPerLine.Array.data[1]
